# Frontend talks to the local API by default.
VITE_API_BASE_URL=http://localhost:8787

# Optional: override the file URL sent to the vacuum if auto-detected LAN IP is wrong.
# PUBLIC_FILE_BASE_URL=http://192.168.1.10:8787

# Default is discovery/preparation only. Set to send after confirming the X40 payload.
# DREAME_VOICE_INSTALL_MODE=send

# CORS origin for the local Vite app.
ALLOWED_ORIGIN=http://localhost:5173

# Port for `npm run local` built frontend server.
# WEB_PORT=5175
